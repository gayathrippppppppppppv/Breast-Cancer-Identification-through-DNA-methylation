# =============================
# Step 3: Variance filtering (top 25%)
# =============================
variances = meth.var(axis=1)
threshold = variances.quantile(0.75)
meth = meth.loc[variances >= threshold]
print(f"📉 After variance filtering: {meth.shape}")

# =============================
# Save cleaned methylation
# =============================
