# Step 1: Remove CpGs with >20% missing values
# =============================
missing_frac = meth.isna().mean(axis=1)
meth = meth.loc[missing_frac <= 0.20]
print(f"🧹 After CpG missing-value filter: {meth.shape}")

# =============================
# Step 2: Impute remaining NaNs (row median)
# =============================
